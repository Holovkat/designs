{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/privacy-settings.schema.json",
  "title": "Privacy & Retention Settings",
  "type": "object",
  "properties": {
    "telemetry_retention_days": { "type": "integer", "minimum": 1, "default": 2555 },
    "orders_retention_days": { "type": "integer", "minimum": 1, "default": 2555 },
    "pod_artifacts_retention_days": { "type": "integer", "minimum": 1, "default": 2555 },
    "eu_short_retention_default": { "type": "boolean", "default": false, "description": "If true, EU tenants default to shorter telemetry retention (e.g., 30 days)" },
    "analytics_opt_in": { "type": "boolean", "default": true },
    "event_pii_allowed": { "type": "boolean", "default": false, "description": "If true, allow limited PII in events (generally discouraged)." }
  },
  "additionalProperties": true
}

