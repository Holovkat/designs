{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.fms.local/integration/flow.executed.v1.json",
  "title": "Integration Flow Executed v1",
  "type": "object",
  "allOf": [{"$ref": "_common.json"}],
  "properties": {
    "event": {
      "type": "object",
      "properties": {
        "flowName": {"type": "string"},
        "flowVersion": {"type": "string"},
        "externalSystem": {"type": "string"},
        "operation": {"type": "string"},
        "status": {"type": "string", "enum": ["success","partial","skipped"]},
        "durationMs": {"type": "number"}
      },
      "required": ["flowName","externalSystem","operation","status"]
    }
  },
  "required": ["eventId","specVersion","occurredAt","tenantId","producer","event"],
  "additionalProperties": false
}
