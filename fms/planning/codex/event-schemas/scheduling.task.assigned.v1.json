{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.fms.local/scheduling/task.assigned.v1.json",
  "title": "Task Assigned v1",
  "type": "object",
  "allOf": [{"$ref": "_common.json"}],
  "properties": {
    "event": {
      "type": "object",
      "properties": {
        "taskId": {"type": "string"},
        "routeId": {"type": "string"},
        "vehicleId": {"type": "string"},
        "driverId": {"type": "string"},
        "plannedPickup": {"type": "string", "format": "date-time"},
        "plannedDropoff": {"type": "string", "format": "date-time"}
      },
      "required": ["taskId", "routeId", "vehicleId", "driverId"]
    }
  },
  "required": ["eventId", "specVersion", "occurredAt", "tenantId", "producer", "event"],
  "additionalProperties": false
}
