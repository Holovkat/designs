{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.fms.local/config.changed.v1.json",
  "title": "Config Changed v1",
  "type": "object",
  "allOf": [{"$ref": "_common.json"}],
  "properties": {
    "event": {
      "type": "object",
      "properties": {
        "tenantId": {"type": "string"},
        "keys": {"type": "array", "items": {"type": "string"}},
        "scope": {"type": "string", "enum": ["global","tenant"]},
        "version": {"type": "string"}
      },
      "required": ["keys","scope"]
    }
  },
  "required": ["eventId","specVersion","occurredAt","tenantId","producer","event"],
  "additionalProperties": false
}
