{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "FMS-GLM Design System",
  "version": "1.0.0",
  "description": "Fleet Management System design tokens - warm cream/orange 'Solar Dusk' theme with minimalist borderless design philosophy from Notional",
  "metadata": {
    "framework": "Next.js 16 + React 19",
    "styling": "Tailwind CSS v4",
    "components": "shadcn/ui (new-york style)",
    "icons": "Lucide React",
    "colorSpace": "OKLCH",
    "designPhilosophy": "Minimalist, borderless, progressive disclosure",
    "influences": ["Notional", "Notion", "Linear"]
  },
  "designPrinciples": {
    "borderlessFirst": {
      "description": "Default to no borders; use subtle backgrounds for separation",
      "pattern": "bg-card hover:shadow-md transition-shadow"
    },
    "progressiveDisclosure": {
      "description": "Show controls on hover, hide when not needed",
      "pattern": "opacity-0 group-hover:opacity-100 transition-opacity"
    },
    "opacityHierarchy": {
      "description": "Use opacity for visual hierarchy",
      "subtle": "opacity-30",
      "hover": "hover:opacity-100",
      "muted": "opacity-60"
    },
    "subtleElevation": {
      "description": "Prefer backdrop blur over heavy shadows",
      "pattern": "bg-card/90 backdrop-blur-sm shadow-lg"
    },
    "watermarkBranding": {
      "description": "Ultra-light, non-intrusive brand presence",
      "pattern": "text-[2rem] font-extralight opacity-20 pointer-events-none select-none"
    },
    "verticalEllipsisActions": {
      "description": "All edit/delete actions hidden behind vertical ellipsis menu on hover",
      "triggerClass": "absolute top-2 right-2 h-7 w-7 opacity-0 group-hover:opacity-100 transition-opacity",
      "parentClass": "relative group"
    },
    "inlineCreation": {
      "description": "Add new buttons as ghost elements within lists, not toolbar buttons",
      "ghostCard": "w-full p-4 border border-dashed border-border rounded-lg opacity-40 hover:opacity-100 hover:border-primary hover:bg-card transition-all",
      "ghostCardContent": "flex items-center gap-2 text-muted-foreground group-hover:text-primary"
    },
    "clickToInspect": {
      "description": "Clicking list items opens slide-out inspector panel",
      "selectionRing": "ring-2 ring-primary shadow-md",
      "inspectorWidth": "xl"
    },
    "inspectorPanel": {
      "description": "Slide-out detail panel with header, tabbed content, and conditional footer",
      "structure": ["header (title + close)", "tabs (scrollable content)", "footer (only when dirty)"],
      "headerClass": "flex items-center justify-between p-4 border-b shrink-0",
      "footerClass": "flex items-center justify-end gap-2 p-4 border-t shrink-0"
    }
  },
