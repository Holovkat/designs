{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/features-settings.schema.json",
  "title": "Feature Flags & UI Settings",
  "type": "object",
  "properties": {
    "paid_features": {
      "type": "object",
      "properties": {
        "forecasting": { "type": "boolean", "default": false }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "properties": {
        "allow_forecast_entry": { "type": "boolean", "default": false },
        "allowed_order_creation_statuses": {
          "type": "array",
          "items": { "type": "string", "enum": ["forecast","provisional","firm"] },
          "uniqueItems": true,
          "default": ["provisional","firm"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

