{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/reports-settings.schema.json",
  "title": "Reports Settings",
  "type": "object",
  "properties": {
    "header_text": { "type": "string", "maxLength": 120, "default": "" },
    "footer_text": { "type": "string", "maxLength": 200, "default": "" },
    "logo_url": {
      "type": ["string","null"],
      "pattern": "^https?://.+$",
      "description": "Optional report-specific logo URL (overrides tenant brand logo)"
    },
    "watermark": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "text": { "type": "string", "default": "CONFIDENTIAL", "maxLength": 60 },
        "opacity": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.15 }
      },
      "required": ["enabled", "text", "opacity"],
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "properties": {
        "pdf_page_size": { "type": "string", "enum": ["A4", "Letter"], "default": "A4" },
        "pdf_orientation": { "type": "string", "enum": ["portrait", "landscape"], "default": "landscape" },
        "timezone": { "type": "string", "default": "Australia/Sydney" },
        "csv_delimiter": { "type": "string", "enum": [",", ";", "\t"], "default": "," }
      },
      "required": ["pdf_page_size", "pdf_orientation", "timezone", "csv_delimiter"],
      "additionalProperties": false
    }
  },
  "required": ["watermark", "defaults"],
  "additionalProperties": true
}

