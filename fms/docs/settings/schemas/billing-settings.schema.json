{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/billing-settings.schema.json",
  "title": "Billing Settings",
  "type": "object",
  "properties": {
    "included_loads_default": {
      "type": "integer",
      "minimum": 0,
      "default": 1000,
      "description": "Default monthly included transport loads in the base plan"
    },
    "pack_catalog": {
      "type": "array",
      "description": "Available top-up packs",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "loads": { "type": "integer", "minimum": 1 },
          "discount_pct": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "required": ["id","title","loads","discount_pct"]
      },
      "default": [
        {"id": "pack_1k_10", "title": "Top‑Up 1,000 Loads (10% off)", "loads": 1000, "discount_pct": 10},
        {"id": "pack_5k_15", "title": "Top‑Up 5,000 Loads (15% off)", "loads": 5000, "discount_pct": 15}
      ]
    },
    "proration_enabled": {
      "type": "boolean",
      "default": true
    },
    "allow_topups": {
      "type": "boolean",
      "default": true
    },
    "allow_payg": {
      "type": "boolean",
      "default": true
    },
    "payg_unit_price_aud": {
      "type": "number",
      "minimum": 0,
      "default": 1.0,
      "description": "Default per-load overage price (AUD) when no packs remain"
    },
    "usage_alert_thresholds_percent": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1, "maximum": 100 },
      "uniqueItems": true,
      "default": [90, 100],
      "description": "Usage thresholds (in %) that trigger alerts and inline top-up prompts"
    },
    "inline_topup_prompt_enabled": {
      "type": "boolean",
      "default": true,
      "description": "If true, show inline 'Buy Top‑Up' prompt when thresholds are crossed"
    }
  },
  "additionalProperties": true
}
