{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/fms/order-ingest-response.schema.json",
  "title": "Order Ingestion Response",
  "type": "object",
  "properties": {
    "status": {"type": "string", "enum": ["ok","partial"]},
    "summary": {
      "type": "object",
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "accepted": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0}
      },
      "required": ["total","accepted","failed"],
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "external_order_id": {"type": "string"},
          "status": {"type": "string", "enum": ["accepted","duplicate","failed"]},
          "order_id": {"type": "string"},
          "version": {"type": "integer"},
          "error": {
            "type": "object",
            "properties": {
              "code": {"type": "string"},
              "message": {"type": "string"}
            },
            "required": ["code","message"],
            "additionalProperties": false
          }
        },
        "required": ["external_order_id","status"],
        "additionalProperties": false
      }
    }
  },
  "required": ["status","summary","results"],
  "additionalProperties": false
}
