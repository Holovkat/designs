{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/theme-settings.schema.json",
  "title": "Tenant Theme Settings",
  "type": "object",
  "properties": {
    "theme_id": {
      "type": "string",
      "enum": [
        "ocean", "forest", "desert", "plum", "slate",
        "sunrise", "dusk", "emerald", "amber", "cobalt"
      ],
      "default": "slate"
    },
    "colors": {
      "type": "object",
      "description": "Derived CSS variables honoring 60:20:10 ratio",
      "properties": {
        "background_60": { "type": "string", "pattern": "^#([0-9a-fA-F]{6})$" },
        "text_20":       { "type": "string", "pattern": "^#([0-9a-fA-F]{6})$" },
        "accent_10":     { "type": "string", "pattern": "^#([0-9a-fA-F]{6})$" }
      },
      "required": ["background_60", "text_20", "accent_10"],
      "additionalProperties": false
    }
  },
  "required": ["theme_id", "colors"],
  "additionalProperties": true,
  "examples": [
    {
      "theme_id": "ocean",
      "colors": {
        "background_60": "#0B1E2D",
        "text_20": "#DCE7F2",
        "accent_10": "#00B4D8"
      }
    }
  ]
}

