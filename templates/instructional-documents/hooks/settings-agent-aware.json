{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/pre-commit-workflow.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/post-commit-push.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Create",
        "hooks": [
          {
            "type": "command",
            "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "commands": {
    "sanity-check": {
      "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/sanity-check.sh",
      "description": "Run sanity check to verify app loads correctly"
    },
    "code-review": {
      "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/code-review-checkpoint.sh",
      "description": "Get a second droid opinion on recent changes"
    },
    "end-session": {
      "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/sanity-check.sh && \"$FACTORY_PROJECT_DIR\"/.factory/hooks/code-review-checkpoint.sh",
      "description": "Run full sanity check and code review before ending session"
    }
  }
}
