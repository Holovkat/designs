{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/fms/outbound-event.schema.json",
  "title": "FMS Outbound Domain Event",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "type": {
      "type": "string",
      "enum": [
        "order.created","order.updated","order.cancelled",
        "task.scheduled","task.rescheduled",
        "vehicle.departed_for_route",
        "arrived.at_pickup","departed.from_pickup","arrived.at_dropoff","delivered",
        "exception.raised","exception.resolved","pod.received",
        "order.planning_updated","order.firming_due","order.firmed"
      ]
    },
    "occurred_at": {"type": "string", "format": "date-time"},
    "correlation_id": {"type": "string"},
    "mode": {"type": "string", "enum": ["road","rail","sea"]},
    "payload": {"type": "object"}
  },
  "required": ["id","tenant_id","type","occurred_at","payload"],
  "additionalProperties": false
}
