{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/alerts-settings.schema.json",
  "title": "Alerts & Notifications Settings",
  "type": "object",
  "properties": {
    "toast": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "auto_dismiss_seconds": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer", "default": 20 },
            "high": { "type": "integer", "default": 12 },
            "medium": { "type": "integer", "default": 8 },
            "low": { "type": "integer", "default": 5 }
          },
          "required": ["critical","high","medium","low"],
          "additionalProperties": false
        },
        "dedupe_window_seconds": { "type": "integer", "default": 60 },
        "max_stack": { "type": "integer", "default": 3 }
      },
      "additionalProperties": true
    },
    "inbox": {
      "type": "object",
      "properties": {
        "retention_days": { "type": "integer", "default": 180 },
        "default_folder": { "type": "string", "enum": ["inbox","read","shelved"], "default": "inbox" }
      },
      "additionalProperties": true
    },
    "connectivity": {
      "type": "object",
      "properties": {
        "lost_minutes_threshold": { "type": "integer", "minimum": 1, "default": 2 },
        "battery_low_percent": { "type": "integer", "minimum": 1, "maximum": 100, "default": 15 }
      },
      "additionalProperties": true
    },
    "escalation": {
      "type": "object",
      "properties": {
        "critical_unacked_minutes": { "type": "integer", "default": 15 },
        "email_provider": { "type": "string", "enum": ["clicksend"], "default": "clicksend" },
        "sms_provider": { "type": "string", "enum": ["clicksend"], "default": "clicksend" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
