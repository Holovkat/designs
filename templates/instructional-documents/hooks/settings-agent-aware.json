{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/pre-commit-workflow.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/post-commit-push.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Create",
        "hooks": [
          {
            "type": "command",
            "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "commands": {
    "sanity-check": {
      "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/sanity-check.sh",
      "description": "Run sanity check to verify app loads correctly"
    },
    "code-review": {
      "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/code-review-checkpoint.sh",
      "description": "Get a second agent review on recent changes"
    },
    "end-session": {
      "command": "\"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/sanity-check.sh && \"${WORKFLOW_PROJECT_DIR:-${FACTORY_PROJECT_DIR:-$PWD}}\"/hooks/code-review-checkpoint.sh",
      "description": "Run full sanity check and code review before ending session"
    }
  }
}
