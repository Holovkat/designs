{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/zone-settings.schema.json",
  "title": "Zone Settings",
  "type": "object",
  "properties": {
    "routing": {
      "type": "object",
      "properties": {
        "max_stops_per_route": { "type": "integer", "minimum": 1, "maximum": 200 },
        "reopt_delay_trigger_minutes": { "type": "integer", "minimum": 1, "maximum": 120 },
        "allow_cross_zone_roaming": { "type": "boolean" },
        "roaming_penalty": { "type": "number", "minimum": 0 }
      },
      "required": ["max_stops_per_route", "reopt_delay_trigger_minutes"],
      "additionalProperties": false
    },
    "alerts": {
      "type": "object",
      "properties": {
        "delay_threshold_minutes": { "type": "integer", "minimum": 1, "maximum": 120 },
        "geofence_deviation_percent": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "required": ["delay_threshold_minutes"],
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "properties": {
        "speed_cap_kph": { "type": "number", "minimum": 10, "maximum": 150 },
        "fatigue_check_interval_minutes": { "type": "integer", "minimum": 15, "maximum": 240 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

