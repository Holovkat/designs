{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "registryVersion": "1.0",
  "groups": [
    {"group": "routing", "label": "Routing", "ownerRole": "FleetManager"},
    {"group": "telemetry", "label": "Telemetry", "ownerRole": "Dispatcher"},
    {"group": "dashboard", "label": "Dashboard", "ownerRole": "Dispatcher"}
  ],
  "keys": [
    {
      "key": "routing.objective",
      "group": "routing",
      "label": "Optimization Objective",
      "description": "Primary optimization goal for route solver.",
      "type": "string",
      "enum": ["time", "distance", "cost"],
      "default": "time",
      "scopable": ["global", "tenant"],
      "editableBy": ["Admin", "FleetManager"],
      "rollout": "none",
      "requiresRestart": false
    },
    {
      "key": "telemetry.sampleSeconds",
      "group": "telemetry",
      "label": "GPS Sample Interval (s)",
      "type": "number",
      "min": 5,
      "max": 120,
      "default": 15,
      "scopable": ["global", "tenant"],
      "editableBy": ["Admin", "Dispatcher"],
      "rollout": "none",
      "requiresRestart": false
    },
    {
      "key": "dashboard.refreshMs",
      "group": "dashboard",
      "label": "Dashboard Refresh Interval (ms)",
      "type": "number",
      "min": 500,
      "max": 10000,
      "default": 1000,
      "scopable": ["global", "tenant"],
      "editableBy": ["Admin", "Dispatcher"],
      "rollout": "none",
      "requiresRestart": false
    },
    {
      "key": "integrations.erp.apiKey",
      "group": "integrations",
      "label": "ERP API Key",
      "type": "string",
      "isSecret": true,
      "default": null,
      "scopable": ["tenant"],
      "editableBy": ["Admin"],
      "rollout": "none",
      "requiresRestart": false
    }
  ]
}

